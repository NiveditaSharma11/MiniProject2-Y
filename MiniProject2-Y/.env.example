# ── Smart Energy Grid — Environment Variables Template ────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.

# OpenWeatherMap API Key (get from https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Flask secret key for JWT signing (use a long random string in production)
SECRET_KEY=your_secret_key_here

# Path to the historical demand dataset
DATA_PATH=data/continuous dataset.csv

# Set to "true" only during local development, never in production
FLASK_DEBUG=false

# ── Firebase (optional — only needed for Google login) ────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id
